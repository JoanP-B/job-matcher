        "httpMethod": "POST",
        "path": "job-match",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "webhook-job-match-uuid"
    },
    {
