            },
            {
              "name": "job",
              "value": "={{$node[\"Webhook\"].json[\"body\"][\"job\"]}}"
            }
          ]
        },
        "options": {}
      },
      "name": "Call FastAPI Scoring",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Call FastAPI Scoring",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {}
}